# ExpressVPN OpenVPN credentials (from https://www.expressvpn.com/setup#manual)
# These are NOT your ExpressVPN account email/password — they are separate
# credentials shown on the manual configuration page.
OPENVPN_USER=YOUR_OPENVPN_USERNAME
OPENVPN_PASS=YOUR_OPENVPN_PASSWORD

# Which country to connect to (matches filename in vpn-config/, without .ovpn)
# e.g. "nz", "uk", "au" — leave empty to use the first config found
VPN_COUNTRY=
